/**
 * APP LAUNCHER (Electron Base)
 * Fokus: Membuka GUI Dashboard untuk Tim Marketing
 * * Cara Build ke .exe:
 * 1. install electron: npm install electron
 * 2. build: npx electron-packager . App-Launcher --platform=win32 --arch=x64
 */

const { app, BrowserWindow, Menu } = require('electron');
const path = require('path');

function createWindow() {
    const win = new BrowserWindow({
        width: 1280,
        height: 800,
        title: "Surface TikTok - Marketing Dashboard",
        icon: path.join(__dirname, 'assets/icon.ico'), // Opsional
        webPreferences: {
            nodeIntegration: true,
            contextIsolation: false
        },
        backgroundColor: '#0f172a' // Sesuai tema dashboard
    });

    // Menghilangkan menu bar default agar terlihat profesional
    Menu.setApplicationMenu(null);

    // Memuat file dashboard.html yang berada di root folder
    win.loadFile('dashboard.html');

    // Buka DevTools jika diperlukan untuk debugging (opsional)
    // win.webContents.openDevTools();
}

app.whenReady().then(() => {
    createWindow();

    app.on('activate', () => {
        if (BrowserWindow.getAllWindows().length === 0) createWindow();
    });
});

app.on('window-all-closed', () => {
    if (process.platform !== 'darwin') app.quit();
});